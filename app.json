{
  "expo": {
    "name": "Andrade Energy",
    "slug": "andrade-energy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "andradeenergy",
    "userInterfaceStyle": "automatic",
  
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
  "backgroundColor": "#020617",
  "foregroundImage": "./assets/images/android-icon-foreground.png"
},
      "predictiveBackGestureEnabled": false,
      "package": "com.andradese.sun"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#020617"
         
          
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "45f35f6f-4f6a-4452-b2e4-02932e778b2b"
      }
    }
  }
}
